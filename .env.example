# CORS: quien puede llamar al BFF desde el navegador.
# FRONTEND_ORIGINS: lista exacta separada por coma (dev local + dominio propio
# si tienes uno fijo). FRONTEND_ORIGIN_REGEX: patron para los deploys de Vercel
# (produccion y previews). Si dejas el regex, cualquier *.vercel.app pasa.
FRONTEND_ORIGINS=http://localhost:5173,http://localhost:4173
FRONTEND_ORIGIN_REGEX=https://.*\.vercel\.app
